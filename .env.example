# --- Server ---
APP_SECRET_KEY=change-me-to-a-long-random-string
BASE_URL=http://localhost:8000
# Default is "production" (safe). Set to "development" locally to enable API
# docs at /docs and the fuller /healthz. Dev-login/dev-grant are enabled purely
# by the ABSENCE of real Google/Razorpay keys, so a live deploy is safe either way.
ENVIRONMENT=development
# Set true ONLY when behind a trusted reverse proxy (e.g. Render) so the rate
# limiter can read the forwarded client IP. Leave false for direct/local runs.
TRUST_PROXY=false

# --- Billing (Razorpay: https://dashboard.razorpay.com -> API Keys) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CURRENCY=INR
CREDIT_PRICE=49          # price of ONE credit (1 credit = 1 resume generation)
CREDIT_PACKS=3,5,10      # purchasable pack sizes
PRO_PRICE=299            # PRO monthly pass
PRO_MONTHLY_CREDITS=30   # credits granted with each PRO month
SIGNUP_CREDITS=3         # free credits for new accounts

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LLM providers ---
# Configure Gemini and/or Groq. Requests round-robin across ALL keys/models of
# both providers and fail over when one is rate-limited. primary_provider is
# tried first.
PRIMARY_PROVIDER=gemini

# Gemini / Gemma (free: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_API_KEYS=
# Comma-separated model IDs. Adjust if the API returns 404 for a name.
GEMINI_MODELS=gemma-4-31b-it,gemma-4-26b-a4b-it

# Groq (free: https://console.groq.com/keys) — used as fallback by default
GROQ_API_KEY=
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Database ---
# Local dev (no setup): SQLite
# DATABASE_URL=sqlite:///./placeholderai.db
#
# Supabase (free Postgres): Project -> Settings -> Database -> Connection string.
# Use the "Session pooler" URI (port 5432). Replace [YOUR-PASSWORD] and keep
# sslmode=require. The 'postgres://' prefix is auto-normalized for SQLAlchemy.
# Example:
# DATABASE_URL=postgresql://postgres.abcdxyz:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=sqlite:///./placeholderai.db
